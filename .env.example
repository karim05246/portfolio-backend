PORT=5000

# Render free tier blocks SMTP (ports 587/465). Use Resend HTTP API in production:
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Portfolio Contact <onboarding@resend.dev>
RECEIVER_EMAIL=your_email@gmail.com

# Optional: Gmail SMTP (works locally; requires Render paid plan for SMTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password_without_spaces

# Optional
FRONTEND_URL=https://your-portfolio.vercel.app
